</Text>\n\n      <RadioCards.Root value={signupChoice} onValueChange={setSignupChoice}>\n        <RadioCards.Item value=\"client\">Client</RadioCards.Item>\n        <RadioCards.Item value=\"trainer\">Trainer</RadioCards.Item>\n      </RadioCards.Root>\n\n      {signupChoice === 'client' && (\n        <Flex direction=\"column\" gap=\"2\">\n                      <TextField.Root placeholder=\"Name\" required />\n            <TextField.Root type=\"email\" placeholder=\"Email\" required />\n            <TextField.Root type=\"password\" placeholder=\"Password\" required />\n            <TextArea placeholder=\"Fitness goals\" rows={3} required />\n            <TextField.Root placeholder=\"Training styles (e.g. strength, HIIT)\" required />\n            <TextField.Root placeholder=\"Budget (monthly)\" required />\n            <Flex className=\"verify-box\">\n              <Text weight={\"bold\"}>Verification</Text>\n              <Text weight={\"light\"} size={\"1\"}>Complete email and phone verification after signup.</Text>\n            </Flex>\n            <Button type=\"submit\">Create Client Account</Button>\n        </Flex>\n      )}\n      {signupChoice === 'trainer' && (\n        <Flex direction=\"column\" gap=\"2\">\n          <form className=\"stack-form\">\n            <input placeholder=\"Name\" required />\n            <input type=\"email\" placeholder=\"Email\" required />\n            <input type=\"password\" placeholder=\"Password\" required />\n            <input placeholder=\"Certifications\" required />\n            <input placeholder=\"Experience (years)\" required />\n            <input placeholder=\"Specialties\" required />\n            <input placeholder=\"Pricing\" required />\n            <label className=\"field-label\">\n              Upload profile photo\n              <input type=\"file\" accept=\"image/*\" />\n            </label>\n            <label className=\"field-label\">\n              Upload intro video\n              <input type=\"file\" accept=\"video/*\" />\n            </label>\n            <div className=\"verify-box\">\n              <strong>Verification</strong>\n              <p>Complete email and phone verification after signup.</p>\n            </div>\n            <button type=\"submit\">Create Trainer Account</button>\n          </form>\n        </Flex>\n      )}\n      {/* <Tabs.Root value={role} onValueChange={setRole} className=\"tabs-root\">\n        <Tabs.List className=\"tabs-list\" aria-label=\"User role\">\n          <Tabs.Trigger className=\"tabs-trigger\" value=\"client\">\n            Client\n          </Tabs.Trigger>\n          <Tabs.Trigger className=\"tabs-trigger\" value=\"trainer\">\n            Trainer\n          </Tabs.Trigger>\n        </Tabs.List>\n\n        <Tabs.Content value=\"client\" className=\"tabs-content\">\n          <form className=\"stack-form\">\n            <input placeholder=\"Name\" required />\n            <input type=\"email\" placeholder=\"Email\" required />\n            <input type=\"password\" placeholder=\"Password\" required />\n            <textarea placeholder=\"Fitness goals\" rows={3} required />\n            <input placeholder=\"Training styles (e.g. strength, HIIT)\" required />\n            <input placeholder=\"Budget (monthly)\" required />\n            <div className=\"verify-box\">\n              <strong>Verification</strong>\n              <p>Complete email and phone verification after signup.</p>\n            </div>\n            <button type=\"submit\">Create Client Account</button>\n          </form>\n        </Tabs.Content>\n\n        <Tabs.Content value=\"trainer\" className=\"tabs-content\">\n          <form className=\"stack-form\">\n            <input placeholder=\"Name\" required />\n            <input type=\"email\" placeholder=\"Email\" required />\n            <input type=\"password\" placeholder=\"Password\" required />\n            <input placeholder=\"Certifications\" required />\n            <input placeholder=\"Experience (years)\" required />\n            <input placeholder=\"Specialties\" required />\n            <input placeholder=\"Pricing\" required />\n            <label className=\"field-label\">\n              Upload profile photo\n              <input type=\"file\" accept=\"image/*\" />\n            </label>\n            <label className=\"field-label\">\n              Upload intro video\n              <input type=\"file\" accept=\"video/*\" />\n            </label>\n            <div className=\"verify-box\">\n              <strong>Verification</strong>\n              <p>Complete email and phone verification after signup.</p>\n            </div>\n            <button type=\"submit\">Create Trainer Account</button>\n          </form>\n        </Tabs.Content>\n      </Tabs.Root> */}\n    </Flex>\n  );\n};\n\nexport default SignupPage;\n"],"mappings":"AAAA,MAAO,CAAAA,KAAK,EAAIC,QAAQ,KAAQ,OAAO,CACvC,MAAO,GAAK,CAAAC,IAAI,KAAM,sBAAsB,CAC5C,OAAQC,MAAM,CAAEC,IAAI,CAAEC,UAAU,CAAEC,IAAI,CAAEC,QAAQ,CAAEC,SAAS,KAAO,kBAAkB,CAAC,OAAAC,GAAA,IAAAC,IAAA,CAAAC,IAAA,IAAAC,KAAA,yBAErF,KAAM,CAAAC,UAAU,CAAGA,CAAA,GAAM,CACvB,KAAM,CAACC,IAAI,CAAEC,OAAO,CAAC,CAAGd,QAAQ,CAAC,QAAQ,CAAC,CAC1C,KAAM,CAACe,YAAY,CAAEC,eAAe,CAAC,CAAGhB,QAAQ,CAAC,CAAC,CAElD,mBACEW,KAAA,CAACR,IAAI,EAACc,SAAS,CAAC,QAAQ,CAACC,GAAG,CAAC,GAAG,CAACC,SAAS,CAAC,aAAa,CAAAC,QAAA,eACtDX,IAAA,CAACJ,IAAI,EAAAe,QAAA,CAAC,SAAO,CAAM,CAAC,cACpBX,IAAA,CAACJ,IAAI,EAAAe,QAAA,CAAC,+BAA6B,CAAM,CAAC,cAE1CT,KAAA,CAACP,UAAU,CAACiB,IAAI,EAACC,KAAK,CAAEP,YAAa,CAACQ,aAAa,CAAEP,eAAgB,CAAAI,QAAA,eACnEX,IAAA,CAACL,UAAU,CAACoB,IAAI,EAACF,KAAK,CAAC,QAAQ,CAAAF,QAAA,CAAC,QAAM,CAAiB,CAAC,cACxDX,IAAA,CAACL,UAAU,CAACoB,IAAI,EAACF,KAAK,CAAC,SAAS,CAAAF,QAAA,CAAC,SAAO,CAAiB,CAAC,EAC3C,CAAC,CAEjBL,YAAY,GAAK,QAAQ,eACxBJ,KAAA,CAACR,IAAI,EAACc,SAAS,CAAC,QAAQ,CAACC,GAAG,CAAC,GAAG,CAAAE,QAAA,eAClBX,IAAA,CAACF,SAAS,CAACc,IAAI,EAACI,WAAW,CAAC,MAAM,CAACC,QAAQ,MAAE,CAAC,cACxDjB,IAAA,CAACF,SAAS,CAACc,IAAI,EAACM,IAAI,CAAC,OAAO,CAACF,WAAW,CAAC,OAAO,CAACC,QAAQ,MAAE,CAAC,cAC5